{
  "name": "breathkit",
  "version": "1.0.0",
  "description": "Zero-dependency TypeScript library for guided breathing exercises",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "tsc --noEmit && node --import tsx --test src/index.test.ts",
    "prepublishOnly": "npm run test && npm run build"
  },
  "keywords": [
    "breathing",
    "wellness",
    "meditation",
    "anxiety",
    "relaxation",
    "box-breathing",
    "coherence-cardiaque",
    "4-7-8"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Nicolas-Deleplace/breathKit.git"
  },
  "bugs": {
    "url": "https://github.com/Nicolas-Deleplace/breathKit/issues"
  },
  "homepage": "https://github.com/Nicolas-Deleplace/breathKit#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "tsx": "^4.21.0",
    "typescript": "^5.4.0"
  }
}
